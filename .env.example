# Example environment variables for local development
# Copy this file to `.env` and fill in real values before running.

# MongoDB connection string used by `db/conn.js` (required)
ATLAS_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/codex-js?retryWrites=true&w=majority

# Secrets used to sign JWTs (required)
JWT_SECRET=replace_this_with_a_strong_secret
REFRESH_SECRET=replace_this_with_a_different_strong_secret

# Optional token lifetimes
JWT_EXPIRES_IN=30m
REFRESH_EXPIRATION_DAYS=7

# Server settings
PORT=5050
NODE_ENV=development
